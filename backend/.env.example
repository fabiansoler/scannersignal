# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Asistente IA de contexto de mercado (Groq) — conseguí tu key en https://console.groq.com
# Dejar GROQ_API_KEY vacía deshabilita el módulo (el resto de la app funciona igual).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=30000

# Scanner config
SCAN_INTERVAL_MS=10000
MIN_SCORE_ALERT=80
MIN_SCORE_PUBLISH=50
DEFAULT_TIMEFRAME=M5

# Server
PORT=3001

# Descomenta si estás en red corporativa con proxy SSL (mismo problema que npm strict-ssl)
# NODE_TLS_REJECT_UNAUTHORIZED=0
