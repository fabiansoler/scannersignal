# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange API keys (opcionales para datos públicos)
BINANCE_API_KEY=
BINANCE_SECRET=

# Scanner config
SCAN_INTERVAL_MS=10000
MIN_SCORE_ALERT=80
MIN_SCORE_PUBLISH=50
DEFAULT_TIMEFRAME=M5

# Server
PORT=3001

# Descomenta si estás en red corporativa con proxy SSL (mismo problema que npm strict-ssl)
# NODE_TLS_REJECT_UNAUTHORIZED=0
